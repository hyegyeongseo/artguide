DB_DSN=mysql+pymysql://root:devpass@mysql:3306/artref
QDRANT_URL=http://qdrant:6333
S3_ENDPOINT=http://minio:9000
S3_KEY=minio
S3_SECRET=minio12345
S3_BUCKET=artref
# 브라우저가 이미지를 열람할 주소(presigned URL 서명용). 로컬은 그대로. 배포 시 공개 도메인으로.
S3_PUBLIC_ENDPOINT=http://localhost:9000
EMBEDDING_MODEL=open_clip:ViT-B-32:laion2b_s34b_b79k
# --- LLM ---
# 비우면 DummyLLM(오프라인 템플릿, 효과 카드 빈칸). Grok 쓰려면 아래처럼:
#   LLM_PROVIDER=grok
#   XAI_API_KEY=xai-... (본인 키)
# 모델 미지정 시 grok-4.3. 더 빠르고 싼 비추론 모델로 바꾸려면 LLM_MODEL 지정.
LLM_PROVIDER=
LLM_MODEL=grok-4.3
XAI_API_KEY=
# --- AI 예제 이미지 생성 (선택, 백엔드 전용 — 프론트로 보내지 말 것) ---
# 기본 생성기는 Bria(scripts/bria_generate.py). 토큰/비용 사정으로 Gemini→Bria 전환.
BRIA_API_KEY=
BRIA_MODEL=2.3
# (레거시) Gemini 생성기를 쓸 때만:
GEMINI_API_KEY=
# --- 접근 통제 (둘 다 비우면 비활성 = 로컬/WoZ 그대로 동작) ---
# API_KEY 설정 시: 보호 경로에 X-API-Key 또는 Authorization: Bearer 요구(콤마로 다중 키).
API_KEY=
# RATE_LIMIT 예: "60/minute". 비우면 레이트리밋 끔.
RATE_LIMIT=
# REDIS_URL 있으면 레이트리밋을 여러 인스턴스에서 공유(없으면 in-process). 예: redis://redis:6379/0
REDIS_URL=
