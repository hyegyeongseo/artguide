# .env.ai_qc.example — 아래 줄들을 기존 artref/.env 에 *덧붙이세요*(이 파일은 스니펫일 뿐).
# 전부 선택값 — 비워두면 코드 기본값으로 동작합니다.

# ── 생성(선택, 백엔드 전용. 절대 프론트엔드로 노출 금지) ─────────────────────────
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=

# ── QC 게이트 임계값(전부 선택, CLIP ViT-B-32 코사인 대역 0.20~0.35) ────────────
# AI_QC_MIN_ARTWORK=0.45     # scene: 작품(일러스트)일 확률 하한. 미만+analyzable=False면 사진으로 보고 거부
# AI_QC_MIN_CONCEPT=0.22     # cosine(image, concept) 하한. 요청 개념을 안 그린 생성물 차단
# AI_QC_MIN_AXIS=0.20        # cosine(image, axis_probe) 하한. 축 검증/자동태깅 기준
# AI_QC_AXIS_MARGIN=0.0      # 선언 축 검증 시 추가 여유(엄격도 ↑)
# AI_QC_STRICT_ANATOMY=0     # 1이면 인물 해부 비대칭을 hard-reject(기본은 flag 자문)
# AI_QC_ANAT_SYM_LO=0.5      # 좌우 사지 길이비 하한(이 밖이면 비대칭 의심)
# AI_QC_ANAT_SYM_HI=2.0
# AI_QC_AUDIT_LOG=/tmp/ai_qc_audit.jsonl   # 005 마이그레이션 안 했을 때 audit JSONL 폴백 경로
# AI_QC_DEBUG=                # 채우면 audit DB 폴백 사유를 로그로
